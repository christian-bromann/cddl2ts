}

export interface SessionDirectProxyConfiguration extends Extensible {
  proxyType: "direct";
}

export interface SessionManualProxyConfiguration extends SessionSocksProxyConfiguration, Extensible {
  proxyType: "manual";
  httpProxy?: string;
